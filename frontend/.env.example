# API Configuration
#
# API URL (optional)
# If not set, will auto-detect based on deployment:
# - Development: Uses Vite proxy (handles /api requests)
# - Production (same origin on :8000): Uses /api prefix
# - Production (different setup): Uses current host:8000
#
# Override this for custom API endpoints:
# VITE_API_URL=https://api.example.com
# VITE_API_URL=http://localhost:8000
#
# For Docker deployment, leave empty (uses /api prefix)
VITE_API_URL=
