# Frontend development server
FRONTEND_PORT=3000

# Browser-visible backend connection settings used during local development.
# Vite proxies /api requests with the same host/port, and direct websocket
# connections use these values when the frontend runs on FRONTEND_PORT.
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8000

# Optional Playwright override for local e2e runs.
# PW_E2E_WORKERS=4
