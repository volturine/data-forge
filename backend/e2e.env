# E2E test environment — used by `just test-e2e`
# Safe, self-contained config that avoids touching production data.

APP_NAME="Data-Forge E2E"
APP_VERSION="0.0.0-e2e"
DEBUG=false

CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

DATA_DIR=/tmp/polars-fastapi-svelte-e2e
DEFAULT_NAMESPACE=default

UPLOAD_CHUNK_SIZE=5242880

ENGINE_IDLE_TIMEOUT=60
ENGINE_POOLING_INTERVAL=5
JOB_TIMEOUT=120

POLARS_MAX_THREADS=2
POLARS_MAX_MEMORY_MB=0
POLARS_STREAMING_CHUNK_SIZE=0
MAX_CONCURRENT_ENGINES=5

WORKERS=1
WORKER_CONNECTIONS=10
LOG_LEVEL=warning
LOG_QUEUE_OVERFLOW=drop
LOG_MAX_BODY_SIZE=0

PROD_MODE_ENABLED=false

TIMEZONE=UTC
NORMALIZE_TZ=false

AUTH_REQUIRED=true
DEFAULT_USER_EMAIL=default@example.com
DEFAULT_USER_PASSWORD=change-me-123
DEFAULT_USER_NAME="Default User"
